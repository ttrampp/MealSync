@using MealSync.Core.Entities
@using MealSync.Core.Interfaces
@using Microsoft.AspNetCore.Components.Forms

@inject IIngredientService IngredientService

<div class="position-relative">
    <input class="form-control"
           style="cursor: text;"
           placeholder="Search ingredients..."
           value="@SearchText"
           @oninput="OnInputChanged" />
    
    @if (FilteredIngredients.Any())
    {
        <div class="border rounded mt-1 my-dropdown position-absolute w-100" style="z-index: 1000; max-height: 200px; overflow-y: auto;">

            @foreach (var ingredient in FilteredIngredients) {
                <div class="p-2 dropdown-item" style="cursor: pointer;" @onclick="() => SelectedIngredient(ingredient.Name)">
                    @ingredient.Name
                </div>
            }
        </div>
            
    }
</div>

@code {
    [Parameter]
    public string? Value { get; set; }
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }
    [Parameter]
    public EventCallback<string> OnIngredientSelected { get; set; }
    
    private List<Ingredient> FilteredIngredients { get; set; } = new();
    private string? SearchText { get; set; }

    private CancellationTokenSource? _cts;
    private System.Timers.Timer? _debounceTimer;

   

    protected override void OnParametersSet()
    {
        if (SearchText == null && Value != null)
        {
            SearchText = Value;
        }
    }


    private void OnInputChanged(ChangeEventArgs e)
    {
        SearchText = e.Value?.ToString();
        Value = SearchText;

        _ = ValueChanged.InvokeAsync(Value);

        _debounceTimer?.Stop();
        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (_, __) =>
        {
            _debounceTimer?.Stop();
            await InvokeAsync(() => PerformSearchAsync(SearchText));
        };
        _debounceTimer.Start();
    }

    private async Task PerformSearchAsync(string? ingredientName)
{
    _cts?.Cancel();
    _cts = new CancellationTokenSource();

    if (string.IsNullOrWhiteSpace(ingredientName))
    {
        FilteredIngredients.Clear();
        await InvokeAsync(StateHasChanged);
        return;
    }
    
    FilteredIngredients = await IngredientService.SearchAsync(ingredientName);
    
    await InvokeAsync(StateHasChanged);
}


    private async Task SelectedIngredient(string ingredientName) {
        SearchText = ingredientName;
        Value = ingredientName;
        
        await ValueChanged.InvokeAsync(Value);
        await OnIngredientSelected.InvokeAsync(ingredientName);

        FilteredIngredients.Clear();
    }
}