@page "/grocerylist"
@using MealSync.Core.Entities
@using MealSync.Core.Interfaces
@inject IGroceryListService GroceryListService
@inject AuthenticationStateProvider AuthenticationStateProvider
@using System.Security.Claims

@attribute [Authorize]

@inject IJSRuntime JS


@* used AI to get this link from bootstrap *@
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
      
<PageTitle>Grocery List</PageTitle>

<div class="container d-flex gap-3">
    <div id="printArea">
        <h1 class="mb-3">Grocery List</h1>
        @if (groceryList != null && groceryList.Items.Any())
        {

            <ul class="list-group" style="max-width: 500px;">
                @{
                    groceryList.Items.OrderBy(i => i.IsChecked).ThenBy(i => i.Ingredient?.Name);
                    //need to figure out how to impliment this still needs work
                }
                @foreach (var (item, editMenuUI) in ListAndMenu)
                //retrives all grocery items and orders them
                {

                    <li
                        class="list-group-item d-flex justify-content-between align-items-center @(item.IsChecked ? "text-decoration-line-through text-muted" : "")">
                        <div class="form-check">
                            <InputCheckbox @bind-Value="@item.IsChecked" class="form-check-input me-2"
                                           id="@item.Ingredient?.Name" type="checkbox" checked="@item.IsChecked"
                                           @onchange="() => ToggleItem(item)" />
                            <label class="form-check-label" for="@item.Ingredient?.Name">
                                @item.Quantity @item.Unit @item.Ingredient?.Name
                            </label>
                        </div>
                        <div>
                            <span><i @onclick="() => ShowEditItem(editMenuUI)" id="edit-item"
                                         class="fa-solid fa-pen-to-square"></i></span>
                                <span><i id="remove-item" class="fa-solid fa-x"></i></span>
                            </div>
                        </li>


                        @if (editMenuUI.visible)
                        {
                            <EditMenu item="item" editMenuUI="editMenuUI" />
                        }

                    }
                    
                </ul>
            }

        else if (groceryList != null)
            {
                <div class="alert alert-info">Your grocery list is empty. Add meals to your calendar first!</div>
            }

            @if (groceryList != null)
            {
                <span class="span text-muted mt-3 d-block">Generated:
                    @groceryList.CreatedAt.ToLocalTime().ToString("g")</span>
                }
            </div>

            <div class="mt-5 mb-3 d-flex justify-content-start flex-column w-25">

                <label for="date-select"><b>Generate grocery list by range</b></label>
                <select name="date select" id="date-select" @onchange="@OnDateSelected">
                    <button>
                        <selectedcontent></selectedcontent>
                    </button>

                    <option value="">Please select a date range</option>
                    <option value="weekly">Weekly</option>
                    <option value="biweekly">Biweekly</option>
                    <option value="monthly">Monthly</option>
                </select>
    
                <form>
                    <button type="button" class="btn btn-secondary btn-sm" @onclick="AddIngredient">Add New Ingredient</button>
                    @foreach (var (item, index) in groceryListItems.Select((item, i) => (item, i)))
                    {
                        <div class="d-flex mb-2 align-items-center">
                            <InputText class="form-control me-2" placeholder="Ingredient Name"
                                       @bind-Value="item.Ingredient!.Name" />
                            <InputNumber class="form-control me-2" style="width: 100px;" placeholder="Qty"
                                         @bind-Value="item.Quantity" />
                            <InputText class="form-control me-2" style="width: 100px;" placeholder="Unit" @bind-Value="item.Unit" />
                            <button type="button" class="btn btn-danger btn-sm" @onclick="() => RemoveIngredient(index)">X</button>
                        </div>
                    }
                    <div class="form-group">
                        <button type="submit" @onclick="AddNewItem" class="btn btn-primary">Add to List</button>
                    </div>
                </form>
                <button class="btn btn-primary" @onclick="PrintList">Print Grocery List</button>

            </div>
            <div class="d-flex flex-column px-4 justify-center">
                <h1 class="text-center">Recipes</h1>
                <p>Choose from your recipes and add it to your grocery list.</p>
            </div>


        </div>
<script src="https://kit.fontawesome.com/ab8b884ea6.js" crossorigin="anonymous"></script>

@code {
    private GroceryList? groceryList;
    private string? userId;
    private List<GroceryListItem> groceryListItems = new List<GroceryListItem>();

    private List<EditMenuUI> editMenuUIs = new();

    private List<(GroceryListItem groceryList, EditMenuUI editMenuUI)> ListAndMenu = new();


    public async Task OnDateSelected(ChangeEventArgs args)
    {
        if (args.Value?.ToString() == "")
        {
            return;
        }

        if (args.Value != null)
        {
            await GenerateList(args.Value.ToString());
        }
    }

    public async Task PrintList()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    public void ShowEditItem(EditMenuUI editMenuUI)
    {
        if (!editMenuUI.visible)
        {
            editMenuUI.visible = true;
        }
        else
        {
            editMenuUI.visible = false;
        }
    }
    
    private void RemoveIngredient(int index)
    {
        if (index >= 0 && index < groceryListItems.Count)
        {
            groceryListItems.RemoveAt(index);
        }
    }

    private void AddIngredient()
    {
        groceryListItems.Add(new GroceryListItem { Ingredient = new Ingredient() }); //creates a new ingredient and adds it to
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(userId))
        {
            groceryList = await GroceryListService.GetLatestGroceryListAsync(userId);

            //create a menu editor for each grocery list
            if (groceryList?.Items != null)
            {
                foreach (GroceryListItem item in groceryList.Items)
                {
                    ListAndMenu.Add((item, new EditMenuUI()));
                }
            }
        }

    }

    private async Task GenerateList(string? selectedDate)
    {
        if (string.IsNullOrEmpty(userId)) return;

        // Simple implementation: generate for current week starting from today
        var start = DateTime.Today;
        var end = new DateTime();

        if (selectedDate == "weekly")
        {
            end = start.AddDays(7);
        }
        else if (selectedDate == "biweekly")
        {
            end = start.AddDays(14);
        }
        else if (selectedDate == "monthly")
        {
            end = start.AddDays(30);
        }

        groceryList = await GroceryListService.GenerateGroceryListAsync(start, end, userId);
    }

    public async Task AddNewItem()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        var filteredGroceryListItems = groceryListItems
        .Where(item => !string.IsNullOrWhiteSpace(item.Ingredient?.Name))
        .ToList();

        if (groceryList != null)
        {
            await GroceryListService.AddGroceryIngredientAsync(filteredGroceryListItems, groceryList, userId);
        }
    }

    private async Task ToggleItem(GroceryListItem item)
    {
        await GroceryListService.ToggleItemCheckedAsync(item.ListItemId);
        item.IsChecked = !item.IsChecked; // update UI state locally without full reload

    }
}